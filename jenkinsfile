@Library('asgn-09-lib') _

pipeline {

    agent any

    environment {
        IMAGE_NAME = "ashirqayyum/asgn-09-java-app:latest"

       
        REPO_URL = ""

        SONAR_HOST = "http://172.20.0.3:9000"
        SONAR_TOKEN = "sqa_57f41c25ea3f91d254798548ee800fe34b9a7977"
        PROJECT_KEY = "asgn-09-java-app"

        GRADLE_CONTAINER = "gradle-container"

        DEPLOY_SERVER = "10.4.85.6"
        HELM_CHART_PATH = "/Users/mashir/Documents/DevOps Asgn 09 - Monitoring/devops-monitoring-assignment/helm/java-app"
    }

    stages {

        stage('Checkout (SCM)') {
            steps {
                checkout scm
            }
        }

        stage('Gradle Build (Container)') {
            steps {
                gradleBuild(REPO_URL, GRADLE_CONTAINER)
            }
        }

        stage('Copy Artifact to Workspace') {
            steps {
                copyArtifact(
                    GRADLE_CONTAINER,
                    "/tmp/app/build/libs/asgn-09-java-app-1.0.jar",
                    "app/build/libs/app.jar"
                )
            }
        }

        stage('Gradle Sonar Analysis') {
            steps {
                gradleSonar(GRADLE_CONTAINER, SONAR_HOST, SONAR_TOKEN)
            }
        }

        stage('Sonar Quality Gate') {
            steps {
                sonarQualityGate(SONAR_HOST, SONAR_TOKEN, PROJECT_KEY)
            }
        }

        stage('Docker Build') {
            steps {
                buildDockerImage(IMAGE_NAME, "app")
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([string(credentialsId: 'dockerhub-password', variable: 'PASS')]) {
                    pushDockerImage(IMAGE_NAME, "ashirqayyum", PASS)
                }
            }
        }

        stage('Deploy via SSH + Helm') {
            steps {
                withCredentials([
                    sshUserPrivateKey(
                        credentialsId: 'mac-deploy-key',
                        keyFileVariable: 'KEY',
                        usernameVariable: 'USER'
                    )
                ]) {

                    deployHelmViaSSH(
                        USER,
                        DEPLOY_SERVER,
                        KEY,
                        IMAGE_NAME,
                        "asgn-09-java-app",
                        HELM_CHART_PATH
                    )
                }
            }
        }
    }

    post {
        success {
            echo "PIPELINE SUCCESS"
        }
        failure {
            echo "PIPELINE FAILED"
        }
    }
}



























































